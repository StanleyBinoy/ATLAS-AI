# Required for OpenRouter model access.
OPENROUTER_API_KEY=your_key_here

# Optional model override for OpenRouter.
PRIMARY_MODEL=openrouter/free

# Optional local fallback model used when OpenRouter is unavailable.
FALLBACK_MODEL=llama3.2:3b

# Optional local paths for ChromaDB memory and SQLite task logs.
CHROMA_DB_PATH=./chroma_db
SQLITE_DB_PATH=./atlas.db
